       IDENTIFICATION DIVISION.
       PROGRAM-ID. MATCHER.

       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.

       DATA DIVISION.
       FILE SECTION.

       WORKING-STORAGE SECTION.

       01 MATCH-WORK.
           02 WORK-NAME-MATCH-PERCENT      PIC 9(3)V99 VALUE 0.
           02 WORK-NAME-SCORE              PIC 9(3)V99 VALUE 0.
           02 WORK-ALIAS-SCORE             PIC 9(3)V99 VALUE 0.
           02 WORK-BIRTHDAY-SCORE          PIC 9(3)V99 VALUE 0.
           02 WORK-COUNTRY-SCORE           PIC 9(3)V99 VALUE 0.
           02 WORK-TOTAL-MATCH-SCORE       PIC 9(3)V99 VALUE 0.
           02 WORK-MATCH-SCORE-THRESHOLD   PIC 99 VALUE 50.
       
       01 NAME-COMPARISON-WORK.
           02 LEFT-NAME                    PIC X(20).
           02 RIGHT-NAME                   PIC X(20).
           02 NORMALIZED-LEFT-NAME         PIC X(20).
           02 NORMALIZED-RIGHT-NAME        PIC X(20).
           02 LEFT-NAME-LENGTH             PIC 99 VALUE 0.
           02 RIGHT-NAME-LENGTH            PIC 99 VALUE 0.
           02 LONGEST-NAME-LENGTH          PIC 99 VALUE 0.
           02 MATCHING-CHARACTERS          PIC 99 VALUE 0.
           02 NAME-CHAR-INDEX              PIC 99 VALUE 0.
           02 RAW-NAME-MATCH-PERCENT       PIC 9(3)V99 VALUE 0.
           02 CURRENT-CANDIDATE-PERCENT    PIC 9(3)V99 VALUE 0.

       01 BIRTHDAY-COMPARISON-WORK.
           02 CUSTOMER-BIRTHDAY-YYYYMMDD   PIC X(8) VALUE SPACES.
           02 SANCTION-BIRTHDAY-YYYYMMDD   PIC X(8) VALUE SPACES.
           02 CUSTOMER-BIRTHDAY-NUMERIC    PIC 9(8) VALUE 0.
           02 SANCTION-BIRTHDAY-NUMERIC    PIC 9(8) VALUE 0.
           02 CUSTOMER-BIRTHDAY-INTEGER    PIC 9(9) VALUE 0.
           02 SANCTION-BIRTHDAY-INTEGER    PIC 9(9) VALUE 0.
           02 BIRTHDAY-DAY-DIFFERENCE      PIC 9(5) VALUE 0.
           02 MAX-BIRTHDAY-DAY-DIFFERENCE  PIC 9(5) VALUE 1096.
       
       01 CUSTOMER-INDEX PIC 999 VALUE 1.
       01 SANCTION-INDEX PIC 999 VALUE 1.
       
       LINKAGE SECTION.
       01 LINK-CUSTOMERS-WRAPPER.
           COPY "CustomersWrapper.cpy".

       01 LINK-SANCTIONS-WRAPPER.
           COPY "SanctionsWrapper.cpy".

       PROCEDURE DIVISION USING
           LINK-CUSTOMERS-WRAPPER
           LINK-SANCTIONS-WRAPPER.

           PERFORM MATCH-CUSTOMERS-TO-SANCTIONS

       GOBACK.

       MATCH-CUSTOMERS-TO-SANCTIONS.
           PERFORM VARYING CUSTOMER-INDEX FROM 1 BY 1
               UNTIL CUSTOMER-INDEX > CUSTOMERS-COUNT
               PERFORM MATCH-ONE-CUSTOMER-TO-SANCTIONS
           END-PERFORM

       EXIT.

       MATCH-ONE-CUSTOMER-TO-SANCTIONS.
           MOVE 0 TO MATCHED-SANCTIONS-COUNT 
               OF CUSTOMERS(CUSTOMER-INDEX)

           PERFORM VARYING SANCTION-INDEX FROM 1 BY 1
               UNTIL SANCTION-INDEX > SANCTIONS-COUNT
               PERFORM EVALUATE-CUSTOMER-AGAINST-SANCTION
           END-PERFORM

           EXIT.

       EVALUATE-CUSTOMER-AGAINST-SANCTION.
           PERFORM RESET-MATCH-WORK
           PERFORM CALCULATE-NAME-AND-ALIAS-SCORE
           PERFORM CALCULATE-BIRTHDAY-SCORE
           PERFORM CALCULATE-COUNTRY-SCORE
           PERFORM CALCULATE-TOTAL-MATCH-SCORE

           IF WORK-TOTAL-MATCH-SCORE > WORK-MATCH-SCORE-THRESHOLD
               PERFORM ADD-SANCTION-TO-CUSTOMER
           END-IF

       EXIT.

       RESET-MATCH-WORK.
           MOVE 0 TO WORK-NAME-MATCH-PERCENT
           MOVE 0 TO WORK-NAME-SCORE
           MOVE 0 TO WORK-ALIAS-SCORE
           MOVE 0 TO WORK-BIRTHDAY-SCORE
           MOVE 0 TO WORK-COUNTRY-SCORE
           MOVE 0 TO WORK-TOTAL-MATCH-SCORE

       EXIT.

       CALCULATE-NAME-AND-ALIAS-SCORE.
           PERFORM CALCULATE-NAME-SCORE
           PERFORM CALCULATE-ALIAS-SCORE

           IF WORK-ALIAS-SCORE > WORK-NAME-SCORE
               MOVE WORK-ALIAS-SCORE TO WORK-NAME-SCORE
           END-IF

       EXIT.

       CALCULATE-NAME-SCORE.
           MOVE CUSTOMER-NAME OF CUSTOMERS(CUSTOMER-INDEX)
               TO LEFT-NAME

           MOVE SANCTION-NAME OF SANCTIONS(SANCTION-INDEX)
               TO RIGHT-NAME

           PERFORM CALCULATE-NAME-SIMILARITY

           COMPUTE WORK-NAME-SCORE ROUNDED =
               RAW-NAME-MATCH-PERCENT * 50 / 100

           EXIT.

       CALCULATE-ALIAS-SCORE.
           MOVE 0 TO WORK-ALIAS-SCORE

           PERFORM CALCULATE-ALIAS-1-SCORE
           PERFORM CALCULATE-ALIAS-2-SCORE
           PERFORM CALCULATE-ALIAS-3-SCORE
           PERFORM CALCULATE-ALIAS-4-SCORE
           PERFORM CALCULATE-ALIAS-5-SCORE

       EXIT.

       CALCULATE-ALIAS-1-SCORE.
           IF SANCTION-ALIAS-1 OF SANCTIONS(SANCTION-INDEX) NOT = "-"
               MOVE CUSTOMER-NAME OF CUSTOMERS(CUSTOMER-INDEX)
                   TO LEFT-NAME

               MOVE SANCTION-ALIAS-1 OF SANCTIONS(SANCTION-INDEX)
                   TO RIGHT-NAME

               PERFORM CALCULATE-NAME-SIMILARITY

               COMPUTE CURRENT-CANDIDATE-PERCENT ROUNDED =
                   RAW-NAME-MATCH-PERCENT * 10 / 100

               ADD CURRENT-CANDIDATE-PERCENT TO WORK-ALIAS-SCORE
           END-IF

       EXIT.

       CALCULATE-ALIAS-2-SCORE.
           IF SANCTION-ALIAS-2 OF SANCTIONS(SANCTION-INDEX) NOT = "-"
               MOVE CUSTOMER-NAME OF CUSTOMERS(CUSTOMER-INDEX)
                   TO LEFT-NAME

               MOVE SANCTION-ALIAS-2 OF SANCTIONS(SANCTION-INDEX)
                   TO RIGHT-NAME

               PERFORM CALCULATE-NAME-SIMILARITY

               COMPUTE CURRENT-CANDIDATE-PERCENT ROUNDED =
                   RAW-NAME-MATCH-PERCENT * 10 / 100

               ADD CURRENT-CANDIDATE-PERCENT TO WORK-ALIAS-SCORE
           END-IF

       EXIT.

       CALCULATE-ALIAS-3-SCORE.
           IF SANCTION-ALIAS-3 OF SANCTIONS(SANCTION-INDEX) NOT = "-"
               MOVE CUSTOMER-NAME OF CUSTOMERS(CUSTOMER-INDEX)
                   TO LEFT-NAME

               MOVE SANCTION-ALIAS-3 OF SANCTIONS(SANCTION-INDEX)
                   TO RIGHT-NAME

               PERFORM CALCULATE-NAME-SIMILARITY

               COMPUTE CURRENT-CANDIDATE-PERCENT ROUNDED =
                   RAW-NAME-MATCH-PERCENT * 10 / 100

               ADD CURRENT-CANDIDATE-PERCENT TO WORK-ALIAS-SCORE
           END-IF

       EXIT.

       CALCULATE-ALIAS-4-SCORE.
           IF SANCTION-ALIAS-4 OF SANCTIONS(SANCTION-INDEX) NOT = "-"
               MOVE CUSTOMER-NAME OF CUSTOMERS(CUSTOMER-INDEX)
                   TO LEFT-NAME

               MOVE SANCTION-ALIAS-4 OF SANCTIONS(SANCTION-INDEX)
                   TO RIGHT-NAME

               PERFORM CALCULATE-NAME-SIMILARITY

               COMPUTE CURRENT-CANDIDATE-PERCENT ROUNDED =
                   RAW-NAME-MATCH-PERCENT * 10 / 100

               ADD CURRENT-CANDIDATE-PERCENT TO WORK-ALIAS-SCORE
           END-IF

       EXIT.

       CALCULATE-ALIAS-5-SCORE.
           IF SANCTION-ALIAS-5 OF SANCTIONS(SANCTION-INDEX) NOT = "-"
               MOVE CUSTOMER-NAME OF CUSTOMERS(CUSTOMER-INDEX)
                   TO LEFT-NAME

               MOVE SANCTION-ALIAS-5 OF SANCTIONS(SANCTION-INDEX)
                   TO RIGHT-NAME

               PERFORM CALCULATE-NAME-SIMILARITY

               COMPUTE CURRENT-CANDIDATE-PERCENT ROUNDED =
                   RAW-NAME-MATCH-PERCENT * 10 / 100

               ADD CURRENT-CANDIDATE-PERCENT TO WORK-ALIAS-SCORE
           END-IF

       EXIT.

       CALCULATE-NAME-SIMILARITY.
           PERFORM NORMALIZE-COMPARISON-NAMES
           PERFORM CALCULATE-COMPARISON-NAME-LENGTHS
           PERFORM COMPARE-NORMALIZED-NAMES

           IF LONGEST-NAME-LENGTH > 0
               COMPUTE RAW-NAME-MATCH-PERCENT ROUNDED =
                   MATCHING-CHARACTERS * 100 / LONGEST-NAME-LENGTH
           ELSE
               MOVE 0 TO RAW-NAME-MATCH-PERCENT
           END-IF

       EXIT.

       NORMALIZE-COMPARISON-NAMES.
           MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(LEFT-NAME))
               TO NORMALIZED-LEFT-NAME

           MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(RIGHT-NAME))
               TO NORMALIZED-RIGHT-NAME

           EXIT.

       CALCULATE-COMPARISON-NAME-LENGTHS.
           MOVE FUNCTION LENGTH(FUNCTION TRIM(NORMALIZED-LEFT-NAME))
               TO LEFT-NAME-LENGTH

           MOVE FUNCTION LENGTH(FUNCTION TRIM(NORMALIZED-RIGHT-NAME))
               TO RIGHT-NAME-LENGTH

           IF LEFT-NAME-LENGTH >= RIGHT-NAME-LENGTH
               MOVE LEFT-NAME-LENGTH TO LONGEST-NAME-LENGTH
           ELSE
               MOVE RIGHT-NAME-LENGTH TO LONGEST-NAME-LENGTH
           END-IF

           EXIT.

       COMPARE-NORMALIZED-NAMES.
           MOVE 0 TO MATCHING-CHARACTERS

           PERFORM VARYING NAME-CHAR-INDEX FROM 1 BY 1
               UNTIL NAME-CHAR-INDEX > LONGEST-NAME-LENGTH
               IF NORMALIZED-LEFT-NAME(NAME-CHAR-INDEX:1)
                  = NORMALIZED-RIGHT-NAME(NAME-CHAR-INDEX:1)
                   ADD 1 TO MATCHING-CHARACTERS
               END-IF
           END-PERFORM

           EXIT.

       CALCULATE-BIRTHDAY-SCORE.
           MOVE 0 TO WORK-BIRTHDAY-SCORE

           PERFORM LOAD-BIRTHDAY-DATE-DATA
           PERFORM CALCULATE-BIRTHDAY-DAY-DIFFERENCE
           PERFORM CALCULATE-BIRTHDAY-PROXIMITY-SCORE

           EXIT.

       LOAD-BIRTHDAY-DATE-DATA.
           MOVE SPACES TO CUSTOMER-BIRTHDAY-YYYYMMDD
           MOVE SPACES TO SANCTION-BIRTHDAY-YYYYMMDD

           MOVE SANCTION-FORMATTED-BIRTHDAY 
               OF CUSTOMERS(CUSTOMER-INDEX)(1:4)
               TO CUSTOMER-BIRTHDAY-YYYYMMDD(1:4)
           MOVE SANCTION-FORMATTED-BIRTHDAY 
               OF CUSTOMERS(CUSTOMER-INDEX)(6:2)
               TO CUSTOMER-BIRTHDAY-YYYYMMDD(5:2)
           MOVE SANCTION-FORMATTED-BIRTHDAY 
               OF CUSTOMERS(CUSTOMER-INDEX)(9:2)
               TO CUSTOMER-BIRTHDAY-YYYYMMDD(7:2)

           MOVE SANCTION-BIRTHDATE OF SANCTIONS(SANCTION-INDEX)(1:4)
               TO SANCTION-BIRTHDAY-YYYYMMDD(1:4)
           MOVE SANCTION-BIRTHDATE OF SANCTIONS(SANCTION-INDEX)(6:2)
               TO SANCTION-BIRTHDAY-YYYYMMDD(5:2)
           MOVE SANCTION-BIRTHDATE OF SANCTIONS(SANCTION-INDEX)(9:2)
               TO SANCTION-BIRTHDAY-YYYYMMDD(7:2)

           COMPUTE CUSTOMER-BIRTHDAY-NUMERIC = FUNCTION NUMVAL(
               CUSTOMER-BIRTHDAY-YYYYMMDD)

           COMPUTE SANCTION-BIRTHDAY-NUMERIC = FUNCTION NUMVAL(
               SANCTION-BIRTHDAY-YYYYMMDD)

           COMPUTE CUSTOMER-BIRTHDAY-INTEGER = FUNCTION 
               INTEGER-OF-DATE(CUSTOMER-BIRTHDAY-NUMERIC)

           COMPUTE SANCTION-BIRTHDAY-INTEGER = FUNCTION 
               INTEGER-OF-DATE(SANCTION-BIRTHDAY-NUMERIC)

       EXIT.

       CALCULATE-BIRTHDAY-DAY-DIFFERENCE.
           COMPUTE BIRTHDAY-DAY-DIFFERENCE = FUNCTION ABS(
               CUSTOMER-BIRTHDAY-INTEGER - SANCTION-BIRTHDAY-INTEGER)

       EXIT.

       CALCULATE-BIRTHDAY-PROXIMITY-SCORE.
           IF BIRTHDAY-DAY-DIFFERENCE >= MAX-BIRTHDAY-DAY-DIFFERENCE
               MOVE 0 TO WORK-BIRTHDAY-SCORE
           ELSE
               COMPUTE WORK-BIRTHDAY-SCORE ROUNDED =
                   30 * (
                       MAX-BIRTHDAY-DAY-DIFFERENCE
                       - BIRTHDAY-DAY-DIFFERENCE
                   ) / MAX-BIRTHDAY-DAY-DIFFERENCE
           END-IF

       EXIT.

       CALCULATE-COUNTRY-SCORE.
           IF CUSTOMER-COUNTRY OF CUSTOMERS(CUSTOMER-INDEX)
               = SANCTION-COUNTRY OF SANCTIONS(SANCTION-INDEX)
               MOVE 20 TO WORK-COUNTRY-SCORE
           END-IF

           EXIT.

       CALCULATE-TOTAL-MATCH-SCORE.
           COMPUTE WORK-TOTAL-MATCH-SCORE =
               WORK-NAME-SCORE
               + WORK-BIRTHDAY-SCORE
               + WORK-COUNTRY-SCORE

       EXIT.

       ADD-SANCTION-TO-CUSTOMER.
           IF MATCHED-SANCTIONS-COUNT OF CUSTOMERS(CUSTOMER-INDEX)
               >= MATCHED-SANCTIONS-MAX-COUNT 
                   OF CUSTOMERS(CUSTOMER-INDEX)
               DISPLAY "WARNING: SANCTION ARRAY FULL FOR CUSTOMER "
                   CUSTOMER-ID OF CUSTOMERS(CUSTOMER-INDEX)
               EXIT PARAGRAPH
           END-IF

           ADD 1 TO MATCHED-SANCTIONS-COUNT
               OF CUSTOMERS(CUSTOMER-INDEX)

           MOVE SANCTION-INDEX
               TO MATCHED-SANCTION-INDEX(
                   CUSTOMER-INDEX,
                   MATCHED-SANCTIONS-COUNT OF CUSTOMERS(CUSTOMER-INDEX))

           MOVE WORK-NAME-SCORE
               TO NAME-MATCH-PERCENT(
                   CUSTOMER-INDEX,
                   MATCHED-SANCTIONS-COUNT OF CUSTOMERS(CUSTOMER-INDEX))

           MOVE WORK-ALIAS-SCORE
               TO ALIAS-MATCH-PERCENT(
                   CUSTOMER-INDEX,
                   MATCHED-SANCTIONS-COUNT OF CUSTOMERS(CUSTOMER-INDEX))

           MOVE WORK-BIRTHDAY-SCORE
               TO BIRTHDAY-MATCH-PERCENT(
                   CUSTOMER-INDEX,
                   MATCHED-SANCTIONS-COUNT OF CUSTOMERS(CUSTOMER-INDEX))

           MOVE WORK-COUNTRY-SCORE
               TO COUNTRY-MATCH-PERCENT(
                   CUSTOMER-INDEX,
                   MATCHED-SANCTIONS-COUNT OF CUSTOMERS(CUSTOMER-INDEX))

           MOVE WORK-TOTAL-MATCH-SCORE
               TO TOTAL-MATCH-PERCENT(
                   CUSTOMER-INDEX,
                   MATCHED-SANCTIONS-COUNT OF CUSTOMERS(CUSTOMER-INDEX))

       EXIT.
